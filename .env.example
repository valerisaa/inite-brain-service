# INITE Brain Service — environment variables

# ── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
# Request logger format: "text" (default in dev), "json" (default in prod).
# Override either way via this env var.
LOG_FORMAT=text

# ── SurrealDB ────────────────────────────────────────────────────────────
# Implementation plan: namespace-per-company isolation.
# Connection points to a single SurrealDB cluster; databases are created
# on-demand per companyId (NS=brain DB=co_<companyId>).
SURREALDB_URL=ws://localhost:8000
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_NAMESPACE=brain
# Connection pool size. Each request acquires one idle conn; queue when exhausted.
# Sized for expected concurrent-request count, not tenants — tenants share the pool.
SURREALDB_POOL_SIZE=8

# ── DB-level PII enforcement (A1) ────────────────────────────────────────
# When SURREALDB_SCOPED_USER + SURREALDB_SCOPED_PASS are set, brain spins
# up a SECOND pool of connections signed in as a non-root EDITOR user
# (created by migration 0005). Caller-facing reads (search, profile,
# timeline, connections, artifacts) route through this scoped pool; the
# per-request `LET $caller_scopes = $scopes` session variable is read by
# PERMISSIONS clauses on PII-classed predicate fields. Without these env
# vars, the service falls back to the root pool with app-layer filtering
# only (defense-in-depth at JS layer, not DB level).
SURREALDB_SCOPED_POOL_SIZE=8
# SURREALDB_SCOPED_USER=brain_caller
# SURREALDB_SCOPED_PASS=brain-caller-password-must-be-overridden-via-env

# ── OpenAI (embeddings + extraction) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# Resilience knobs for OpenAI calls. The SDK's built-in retry handles 429/5xx
# after the request reaches the API; timeout protects against hung sockets,
# concurrency limits the in-flight fan-out per process so a burst of ingests
# doesn't trip the per-key rate ceiling before retries can kick in.
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=3
OPENAI_CONCURRENCY=8

# Embedding cache. Identical input → identical embedding for text-embedding-3-*,
# so we LRU-cache by sha256(model:dim:text). Sized in entries; ~6 KB per
# 1536-dim vector → 2000 entries ≈ 12 MB.
EMBEDDING_CACHE_SIZE=2000

# Optional override for the entity/fact extraction prompt. If unset, falls
# back to the canonical multi-vertical prompt baked into the service.
# EXTRACTION_SYSTEM_PROMPT=

# ── Search reranker (optional) ───────────────────────────────────────────
# Listwise LLM-based re-ranker that runs after vector+lexical fusion on
# the top-N candidates. Joint scoring of (query, candidate) lets the
# model resolve IS-A and predicate-class semantics that cosine misses
# (e.g. "appliance issues" matching a fact about a washing machine).
#
# Off by default — it adds one gpt-4o-mini call per /v1/search request
# (~250-500ms p95, ~$0.0003/query). On the quality eval it lifts
# overall recall@1 from 0.85 to 0.88-0.90 (median), with vertical-level
# wins of +25-40pp on adversarial scenarios (estate, events, shop).
SEARCH_RERANKER_ENABLED=0
# Override the model used for re-ranking. Defaults to OPENAI_CHAT_MODEL.
# SEARCH_RERANKER_MODEL=gpt-4o-mini
# In-flight LLM calls limit for the re-ranker pool.
SEARCH_RERANKER_CONCURRENCY=4
# Permutation Self-Consistency (Tang et al., NAACL 2024). Number of
# parallel reranker calls with shuffled candidate orders, aggregated
# via Borda count. Marginalises positional bias and run-to-run jitter.
# Cost is N× tokens (latency stays ~constant — calls fire in parallel).
# 1 = single call, no SC. Common values: 1, 3, 5.
#
# Measured on the 30-query eval, stacked with type-hint + neighbourhood
# injection: SC_N=3 lifts median recall@1 from 0.88 to 0.93, MRR from
# 0.93 to 0.96, AND collapses run-to-run variance (range 0.02 vs 0.12).
# Both effects together — recommended for production with the rest of
# the rerank+router stack on. Standalone (without type+nbr context),
# the effect was inconclusive — it shines when there's enough query-
# level context for the listwise model to actually leverage the
# multi-shuffle signal.
SEARCH_RERANKER_SC_N=1

# ── Predicate-class + type-aware query router (optional) ─────────────────
# Single LLM call classifies the query into TWO joint distributions:
#   - predicate-class (`name`, `tier`, `complained_about`, `intent`, ...)
#   - target entity-type (`customer`, `staff`, `project`, `asset`, ...)
# Predicate distribution applies a bounded boost to facts whose
# predicate matches; type distribution is surfaced as a hint inside
# the reranker prompt — solves the "Project Phoenix kickoff" hub
# problem where the project entity outranked the staff who attended.
#
# When the reranker is enabled, the search pipeline ALSO injects
# 1-hop neighbourhoods into each candidate's reranker body
# (SubgraphRAG-style) so the LLM sees structural context that
# pure embedding cosine misses. No extra LLM call — neighbours
# are fetched in a single batched graph query.
#
# Best measured combo (reranker+router with all of the above on):
# overall recall@1 0.93, MRR 0.96 — peak 0.95-0.97 across runs,
# with cross 1.00, estate 1.00, "Project Phoenix kickoff" → #1 staff.
SEARCH_PREDICATE_ROUTER_ENABLED=0
# SEARCH_PREDICATE_ROUTER_MODEL=gpt-4o-mini
SEARCH_PREDICATE_ROUTER_CONCURRENCY=4
# LRU cache size — same query maps to same predicate distribution,
# so we don't pay per-LLM call repeatedly on hot UI patterns.
SEARCH_PREDICATE_ROUTER_CACHE=500

# ── HyPE: Hypothetical Prompt Embeddings (optional, ingest-time) ─────────
# At ingest, generate a hypothetical question the fact answers, embed
# it, store as `altEmbedding`. Search vector leg takes
# max(cos(main, q), cos(alt, q)) — closes the question→statement
# embedding gap without paying an LLM call on the read path.
#
# Adds one gpt-4o-mini + one embedding call per fact ingest. On the
# eval the standalone effect was neutral; combined with reranker
# it sometimes hurts. Useful when your queries lean question-form
# and you can't enable the read-path reranker.
SEARCH_HYPE_ENABLED=0
# SEARCH_HYPE_MODEL=gpt-4o-mini
SEARCH_HYPE_CONCURRENCY=4

# ── Personalized PageRank entity prior (optional) ────────────────────────
# HippoRAG-style: seed candidates by their match score, run 3 power
# iterations over the typed-edge graph (mentioned_with, identity_of),
# multiply rankScore by (1 + 0.5·r). One extra graph query per /v1/search.
#
# WARNING: on small per-tenant graphs (≤100 entities) PPR amplifies
# hub nodes — cross-vertical recall@1 dropped from 0.71 to 0.57 on
# the eval because mentioned_with-hub project entities outranked
# their own staff. Useful only when the tenant graph is large
# enough that hub effects don't dominate. Off by default.
SEARCH_PPR_ENABLED=0
# Tier-aware PPR auto-enable: only run PPR when the search's candidate
# set is ≥ N entities. A larger candidate set is a cheap proxy for a
# denser graph, where hub effects no longer dominate. 0 disables auto
# (only the SEARCH_PPR_ENABLED flag controls PPR). Recommended on
# mid-scale deploys: SEARCH_PPR_AUTO_THRESHOLD=100.
SEARCH_PPR_AUTO_THRESHOLD=0

# ── Auth ─────────────────────────────────────────────────────────────────
# For 0.1.0 walking-skeleton: ApiKey is a static map { keyHash → companyId,scope }
# loaded from this env var as JSON. Will be replaced by inite-auth-service
# integration in 0.2.0.
# Example: BRAIN_API_KEYS='[{"keyHash":"sha256:...","companyId":"co_123","scopes":["brain:read","brain:write"]}]'
BRAIN_API_KEYS=[]

# Service-to-service JWT verification.
# When AUTH_SERVICE_JWKS_URL is set, Bearer tokens shaped like JWTs are
# verified against this URL's keys. The token's `sub` is the companyId,
# `scopes` (or `scope`) carry brain scopes. Static BRAIN_API_KEYS still
# works as a fallback unless NODE_ENV=production and JWKS is enabled
# (in that case static keys are rejected — JWTs only).
AUTH_SERVICE_URL=https://auth.inite.ai
AUTH_SERVICE_JWKS_URL=
AUTH_SERVICE_ISSUER=
AUTH_SERVICE_AUDIENCE=brain

# ── Conflict resolution weights (overrides spec defaults) ────────────────
# These mirror the values in inite-ecosystem/core/capabilities/knowledge.yaml
# Override only if you really know what you're doing.
CONFLICT_SIMILARITY_THRESHOLD=0.85
CONFLICT_WEIGHT_CONFIDENCE=0.30
CONFLICT_WEIGHT_SOURCE_TRUST=0.40
CONFLICT_WEIGHT_RECENCY=0.20
CONFLICT_WEIGHT_AUTHORITY=0.10
CONFLICT_MARGIN_SUPERSEDE=0.15
CONFLICT_REJECT_THRESHOLD=0.30

# ── Compaction ───────────────────────────────────────────────────────────
# Daily retention pass: facts whose validUntil/retractedAt is older than
# this many days get status=compacted and lose their embedding.
COMPACTION_HOT_RETENTION_DAYS=90
# When true, compaction creates a per-(entityId, predicate) summary fact
# with derivedFrom linking the originals. Default is false (mark-and-drop
# only) — flip on once you've decided the storage cost of summary embeddings
# is worth the warm-tier search recall.
COMPACTION_SUMMARIES=false

# ── Throttling ───────────────────────────────────────────────────────────
# Per-credential rate limit (the guard hashes the Bearer token for the
# tracker key, so each ApiKey/JWT gets its own bucket). Defaults are
# generous enough for a small-team SaaS — tighten for high-fan-out tiers.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
# Named "expensive" bucket applied to OpenAI-fan-out endpoints (synthesize,
# multi-hop, ingest/mention, demo/chat, dreams/run) via @Throttle in their
# controllers. Stops a single compromised tenant from draining the shared
# OpenAI budget for everyone else.
THROTTLE_EXPENSIVE_TTL_MS=60000
THROTTLE_EXPENSIVE_LIMIT=10

# ── Synthesize guardrail ─────────────────────────────────────────────────
# Conformal-style floor on the isotonic-calibrated confidence below which
# a fact is not eligible as a citation target. 0 disables. Default 0.30
# matches CONFLICT_REJECT_THRESHOLD so a fact admitted as INSERTED is also
# a valid synthesize citation.
SYNTHESIZE_MIN_CONFIDENCE=0.30

# ── Observability ────────────────────────────────────────────────────────
# Enable the OpenTelemetry SDK + GenAI SemConv attributes on every LLM
# call. Endpoint defaults to OTEL_EXPORTER_OTLP_ENDPOINT (standard env).
OTEL_ENABLED=0
