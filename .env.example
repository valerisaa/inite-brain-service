# INITE Brain Service — environment variables

# ── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
# Request logger format: "text" (default in dev), "json" (default in prod).
# Override either way via this env var.
LOG_FORMAT=text

# ── SurrealDB ────────────────────────────────────────────────────────────
# Implementation plan: namespace-per-company isolation.
# Connection points to a single SurrealDB cluster; databases are created
# on-demand per companyId (NS=brain DB=co_<companyId>).
SURREALDB_URL=ws://localhost:8000
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_NAMESPACE=brain
# Connection pool size. Each request acquires one idle conn; queue when exhausted.
# Sized for expected concurrent-request count, not tenants — tenants share the pool.
SURREALDB_POOL_SIZE=8

# ── OpenAI (embeddings + extraction) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# Resilience knobs for OpenAI calls. The SDK's built-in retry handles 429/5xx
# after the request reaches the API; timeout protects against hung sockets,
# concurrency limits the in-flight fan-out per process so a burst of ingests
# doesn't trip the per-key rate ceiling before retries can kick in.
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=3
OPENAI_CONCURRENCY=8

# Embedding cache. Identical input → identical embedding for text-embedding-3-*,
# so we LRU-cache by sha256(model:dim:text). Sized in entries; ~6 KB per
# 1536-dim vector → 2000 entries ≈ 12 MB.
EMBEDDING_CACHE_SIZE=2000

# Optional override for the entity/fact extraction prompt. If unset, falls
# back to the canonical multi-vertical prompt baked into the service.
# EXTRACTION_SYSTEM_PROMPT=

# ── Auth ─────────────────────────────────────────────────────────────────
# For 0.1.0 walking-skeleton: ApiKey is a static map { keyHash → companyId,scope }
# loaded from this env var as JSON. Will be replaced by inite-auth-service
# integration in 0.2.0.
# Example: BRAIN_API_KEYS='[{"keyHash":"sha256:...","companyId":"co_123","scopes":["brain:read","brain:write"]}]'
BRAIN_API_KEYS=[]

# Service-to-service JWT verification.
# When AUTH_SERVICE_JWKS_URL is set, Bearer tokens shaped like JWTs are
# verified against this URL's keys. The token's `sub` is the companyId,
# `scopes` (or `scope`) carry brain scopes. Static BRAIN_API_KEYS still
# works as a fallback unless NODE_ENV=production and JWKS is enabled
# (in that case static keys are rejected — JWTs only).
AUTH_SERVICE_URL=https://auth.inite.ai
AUTH_SERVICE_JWKS_URL=
AUTH_SERVICE_ISSUER=
AUTH_SERVICE_AUDIENCE=brain

# ── Conflict resolution weights (overrides spec defaults) ────────────────
# These mirror the values in inite-ecosystem/core/capabilities/knowledge.yaml
# Override only if you really know what you're doing.
CONFLICT_SIMILARITY_THRESHOLD=0.85
CONFLICT_WEIGHT_CONFIDENCE=0.30
CONFLICT_WEIGHT_SOURCE_TRUST=0.40
CONFLICT_WEIGHT_RECENCY=0.20
CONFLICT_WEIGHT_AUTHORITY=0.10
CONFLICT_MARGIN_SUPERSEDE=0.15
CONFLICT_REJECT_THRESHOLD=0.30

# ── Compaction ───────────────────────────────────────────────────────────
# Daily retention pass: facts whose validUntil/retractedAt is older than
# this many days get status=compacted and lose their embedding.
COMPACTION_HOT_RETENTION_DAYS=90
# When true, compaction creates a per-(entityId, predicate) summary fact
# with derivedFrom linking the originals. Default is false (mark-and-drop
# only) — flip on once you've decided the storage cost of summary embeddings
# is worth the warm-tier search recall.
COMPACTION_SUMMARIES=false

# ── Throttling ───────────────────────────────────────────────────────────
# Per-credential rate limit (the guard hashes the Bearer token for the
# tracker key, so each ApiKey/JWT gets its own bucket). Defaults are
# generous enough for a small-team SaaS — tighten for high-fan-out tiers.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
